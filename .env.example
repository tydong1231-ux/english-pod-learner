VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_REMOTE_ACCESS_PASSWORD=
VITE_DISABLE_LOCAL_ENGINE=false

# Optional Cloudflare Tunnel/local backend settings.
PODFLUENT_TUNNEL_NAME=podfluent
PODFLUENT_CORS_ORIGINS=

# Optional local defaults for AI settings shown in Settings.
# WARNING: VITE_* values are embedded into web builds. Do not put long-lived
# AI provider keys here for a public Cloudflare Pages deployment unless you
# understand that browser users can inspect them.
VITE_GEMINI_API_KEY=
VITE_VOCAB_PROVIDER=gemini
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_MODEL=gpt-4o-mini

# Optional. Required only if you want WhisperX speaker diarization.
# Accept the required pyannote model terms in Hugging Face before using it.
HF_TOKEN=

# Optional. Use this when huggingface.co is unreachable from your network.
# Example for mainland China networks:
# HF_ENDPOINT=https://hf-mirror.com
HF_ENDPOINT=
