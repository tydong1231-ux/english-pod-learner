{
  "name": "english-pod-learner",
  "version": "0.1.0",
  "description": "Local-first English podcast learning app with Supabase, WhisperX, and a cloud read-only web mode.",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "./",
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tydong1231-ux/english-pod-learner.git"
  },
  "bugs": {
    "url": "https://github.com/tydong1231-ux/english-pod-learner/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build --config vite.web.config.js",
    "lint": "eslint .",
    "check": "npm run lint && npm run build && npm run build:web",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.englishpod.learner",
    "productName": "EnglishPod Learner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      "python/**"
    ],
    "win": {
      "target": "dir",
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "2.90.1",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.3",
    "cross-env": "^10.1.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "minimatch@3.1.5": {
      "brace-expansion": "^1.1.13"
    },
    "ws": "^8.20.2"
  }
}
